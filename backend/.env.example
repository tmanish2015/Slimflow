# Copy to .env and fill in. Generate ADMIN_PASSWORD_HASH with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Supabase project — Postgres connection string (Project Settings > Database
# > Connection string > URI; reset the DB password there if you don't have
# it) and the service_role key (Project Settings > API > service_role) used
# server-side only for Storage uploads/downloads. Never expose
# SUPABASE_SERVICE_ROLE_KEY to the frontend.
DATABASE_URL=
SUPABASE_URL=https://drowgscvrpbhdorrczwx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
