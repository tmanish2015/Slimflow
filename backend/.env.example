# Copy to .env and fill in. Generate ADMIN_PASSWORD_HASH with:
#   node -e "console.log(require('bcryptjs').hashSync('your-password', 10))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# Postgres connection string (Supabase project's Project Settings > Database
# > Connection string > URI, or a role created specifically for the app —
# see backend/migrations for how `app_backend` was created). Uploaded
# drawings and OCR previews live in Postgres too (drawing_files table), so
# this is the only datastore credential the app needs.
DATABASE_URL=
